APP_NAME=SynoManager
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/SynoManager/public

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ──────────────────────────────────────────────────────────────────────────────
# Base de données — MySQL requis
# ──────────────────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=synomanager
DB_USERNAME=root
DB_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# Session / Cache / Queue
# ──────────────────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ──────────────────────────────────────────────────────────────────────────────
# SMTP — configurable également depuis l'interface (Paramètres > SMTP)
# ──────────────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ──────────────────────────────────────────────────────────────────────────────
# Synology API
# ──────────────────────────────────────────────────────────────────────────────
SYNOLOGY_TIMEOUT=30
SYNOLOGY_SSL_VERIFY=true

# ──────────────────────────────────────────────────────────────────────────────
# Restriction d'accès à l'interface web (CIDR séparés par virgule)
# Laisser vide pour désactiver (environnement local / dev)
# ──────────────────────────────────────────────────────────────────────────────
ADMIN_ALLOWED_CIDRS=
# IPs/CIDR explicitement bloquées même si dans la range autorisée (deny > allow)
ADMIN_BLOCKED_CIDRS=
# Autoriser l'auto-enregistrement public sur /register (false en production)
REGISTRATION_ENABLED=false
# IPs/CIDR des reverse proxies de confiance (pour lire X-Forwarded-For)
# Utiliser "*" pour faire confiance à tous les proxies (réseau contrôlé uniquement)
TRUSTED_PROXIES=

VITE_APP_NAME="${APP_NAME}"
